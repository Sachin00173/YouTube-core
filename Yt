<script>
// ─────────────────────────────────────────
// CONFIG
// ─────────────────────────────────────────
const YT_KEY = 'AIzaSyDZc3KjfMit_OipZHC_dM2lLGlOINRhuz4';

// Pre-fill key
window.addEventListener('load', () => {
  // User can paste their key here
});

// ─────────────────────────────────────────
// STEP ANIMATION
// ─────────────────────────────────────────
let stepTimer = null;

function startSteps() {
  const ids = ['st1','st2','st3','st4','st5'];
  const delays = [0, 1500, 3500, 6000, 9000];
  ids.forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.className = 'step'; el.querySelector('.step-dot').className = 'step-dot'; }
  });
  delays.forEach((d, i) => {
    setTimeout(() => {
      if (i > 0) {
        const prev = document.getElementById(ids[i-1]);
        if (prev) prev.className = 'step done';
      }
      const cur = document.getElementById(ids[i]);
      if (cur) cur.className = 'step active';
    }, d);
  });
}

function doneSteps() {
  ['st1','st2','st3','st4','st5'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.className = 'step done';
  });
}

// ─────────────────────────────────────────
// URL PARSER
// ─────────────────────────────────────────
function parseInput(input) {
  input = input.trim();

  // Video URL
  const vidMatch = input.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|shorts\/|embed\/))([A-Za-z0-9_-]{11})/);
  if (vidMatch) return { type: 'video', id: vidMatch[1] };

  // Channel handle @
  const handleMatch = input.match(/(?:youtube\.com\/)?@([\w.-]+)/);
  if (handleMatch) return { type: 'handle', id: handleMatch[1] };

  // Channel URL with /channel/UC...
  const channelMatch = input.match(/youtube\.com\/channel\/(UC[\w-]+)/);
  if (channelMatch) return { type: 'channelId', id: channelMatch[1] };

  // Channel URL with /c/ or /user/
  const cMatch = input.match(/youtube\.com\/(?:c\/|user\/)([\w.-]+)/);
  if (cMatch) return { type: 'handle', id: cMatch[1] };

  // Bare channel ID
  if (/^UC[\w-]{20,}$/.test(input)) return { type: 'channelId', id: input };

  // Bare video ID
  if (/^[A-Za-z0-9_-]{11}$/.test(input)) return { type: 'video', id: input };

  // @handle without URL
  if (input.startsWith('@')) return { type: 'handle', id: input.slice(1) };

  return null;
}

// ─────────────────────────────────────────
// YOUTUBE API CALLS
// ─────────────────────────────────────────
async function ytFetch(endpoint, params) {
  let urlStr = `https://www.googleapis.com/youtube/v3/${endpoint}?key=${encodeURIComponent(YT_KEY)}`;
  Object.entries(params).forEach(([k,v]) => {
    urlStr += `&${encodeURIComponent(k)}=${encodeURIComponent(v)}`;
  });
  const res = await fetch(urlStr);
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err?.error?.message || `YouTube API error ${res.status}`);
  }
  return res.json();
}

async function getChannelByHandle(handle) {
  // Try forHandle first
  try {
    const data = await ytFetch('channels', { part: 'snippet,statistics,contentDetails', forHandle: handle });
    if (data.items?.length) return data.items[0];
  } catch {}

  // Try search
  const search = await ytFetch('search', {
    part: 'snippet', type: 'channel', q: handle, maxResults: 1
  });
  if (!search.items?.length) throw new Error(`"${handle}" naam ka channel nahi mila`);
  const cid = search.items[0].snippet.channelId;
  const data = await ytFetch('channels', { part: 'snippet,statistics,contentDetails', id: cid });
  if (!data.items?.length) throw new Error('Channel details nahi mili');
  return data.items[0];
}

async function getChannelById(id) {
  const data = await ytFetch('channels', { part: 'snippet,statistics,contentDetails', id });
  if (!data.items?.length) throw new Error('Channel nahi mila');
  return data.items[0];
}

async function getChannelByVideoId(videoId) {
  const data = await ytFetch('videos', { part: 'snippet,statistics', id: videoId });
  if (!data.items?.length) throw new Error('Video nahi mila');
  const channelId = data.items[0].snippet.channelId;
  const ch = await getChannelById(channelId);
  return { channel: ch, video: data.items[0] };
}

async function getRecentVideos(channelId, maxResults = 20) {
  // Get uploads playlist
  const chData = await ytFetch('channels', { part: 'contentDetails', id: channelId });
  const uploadsId = chData.items?.[0]?.contentDetails?.relatedPlaylists?.uploads;
  if (!uploadsId) return [];

  const pl = await ytFetch('playlistItems', {
    part: 'snippet,contentDetails',
    playlistId: uploadsId,
    maxResults
  });

  if (!pl.items?.length) return [];

  // Fetch video stats
  const ids = pl.items.map(i => i.contentDetails.videoId).join(',');
  const stats = await ytFetch('videos', { part: 'snippet,statistics,contentDetails', id: ids });
  return stats.items || [];
}

// ─────────────────────────────────────────
// DURATION PARSER
// ─────────────────────────────────────────
function parseDuration(iso) {
  if (!iso) return 0;
  const m = iso.match(/PT(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?/);
  if (!m) return 0;
  return (
