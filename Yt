      <div class="step" id="st1"><div class="step-dot"></div>Channel ID dhundh raha hoon</div>
      <div class="step" id="st2"><div class="step-dot"></div>Channel details fetch kar raha hoon</div>
      <div class="step" id="st3"><div class="step-dot"></div>Recent videos analyze kar raha hoon</div>
      <div class="step" id="st4"><div class="step-dot"></div>Content pattern samajh raha hoon</div>
      <div class="step" id="st5"><div class="step-dot"></div>AI se topics generate kar raha hoon</div>
