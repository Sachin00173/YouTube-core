<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Viral Guru — YouTube Analyzer</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap');

:root {
  --bg: #0c0c0f;
  --surface: #141418;
  --card: #1c1c22;
  --border: #2a2a35;
  --red: #ff3b3b;
  --red-dim: rgba(255,59,59,0.12);
  --red-glow: rgba(255,59,59,0.3);
  --orange: #ff8c00;
  --green: #00d97e;
  --blue: #4f9fff;
  --purple: #9d6fff;
  --text: #f0f0f8;
  --sub: #6b6b80;
  --sans: 'Poppins', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  padding-bottom: 60px;
}

/* Ambient */
body::before {
  content: '';
  position: fixed; top: 0; left: 0; right: 0; height: 400px;
  background: radial-gradient(ellipse at 50% 0%, rgba(255,59,59,0.07) 0%, transparent 70%);
  pointer-events: none; z-index: 0;
}

.wrap { max-width: 860px; margin: 0 auto; padding: 0 20px; position: relative; z-index: 1; }

/* ── HEADER ── */
header {
  padding: 36px 0 28px;
  display: flex; align-items: center; gap: 16px;
}

.logo-box {
  width: 48px; height: 48px;
  background: var(--red);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  box-shadow: 0 0 24px var(--red-glow);
  flex-shrink: 0;
}

.logo-text { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; }
.logo-text span { color: var(--red); }
.logo-sub { font-size: 12px; color: var(--sub); margin-top: 2px; }

/* ── API KEY BAR ── */
.api-bar {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 14px 18px;
  display: flex; gap: 10px; align-items: center;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.api-bar label { font-size: 12px; font-weight: 600; color: var(--sub); white-space: nowrap; }

.api-inp {
  flex: 1; min-width: 180px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px 14px;
  color: var(--text);
  font-family: var(--mono);
  font-size: 12px;
  outline: none;
}

.api-inp:focus { border-color: var(--red); }

.save-key-btn {
  background: var(--red-dim);
  border: 1px solid rgba(255,59,59,0.3);
  border-radius: 8px;
  padding: 8px 16px;
  color: var(--red);
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  white-space: nowrap;
}

.save-key-btn:hover { background: rgba(255,59,59,0.2); }

.key-status {
  font-size: 11px;
  font-family: var(--mono);
  padding: 4px 10px;
  border-radius: 6px;
  white-space: nowrap;
}

.key-status.ok { background: rgba(0,217,126,0.12); color: var(--green); }
.key-status.no { background: rgba(255,59,59,0.1); color: var(--red); }

/* ── INPUT SECTION ── */
.input-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 24px;
  margin-bottom: 24px;
}

.input-card h2 {
  font-size: 14px;
  font-weight: 700;
  color: var(--sub);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 14px;
}

.url-row { display: flex; gap: 10px; flex-wrap: wrap; }

.url-inp {
  flex: 1; min-width: 220px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 13px 18px;
  color: var(--text);
  font-family: var(--sans);
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.url-inp:focus {
  border-color: var(--red);
  box-shadow: 0 0 0 3px var(--red-dim);
}

.url-inp::placeholder { color: var(--sub); opacity: 0.6; }

.analyze-btn {
  background: var(--red);
  color: white;
  border: none;
  border-radius: 12px;
  padding: 13px 28px;
  font-family: var(--sans);
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
  white-space: nowrap;
}

.analyze-btn:hover:not(:disabled) {
  opacity: 0.9;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px var(--red-glow);
}

.analyze-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

.hints {
  display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px;
}

.hint {
  font-size: 11px;
  color: var(--sub);
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 4px 10px;
}

/* ── ERROR ── */
.error-box {
  background: rgba(255,59,59,0.08);
  border: 1px solid rgba(255,59,59,0.3);
  border-radius: 12px;
  padding: 14px 18px;
  font-size: 13px;
  color: #ff8080;
  display: none;
  margin-bottom: 16px;
  line-height: 1.6;
}

.error-box.show { display: block; }

/* ── LOADING ── */
.loading-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 48px 32px;
  text-align: center;
  display: none;
  margin-bottom: 24px;
}

.loading-card.show { display: block; }

.spinner {
  width: 44px; height: 44px;
  border: 3px solid var(--border);
  border-top-color: var(--red);
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
  margin: 0 auto 16px;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-title { font-size: 15px; font-weight: 700; margin-bottom: 6px; }
.loading-sub { font-size: 13px; color: var(--sub); margin-bottom: 24px; }

.steps-list { display: flex; flex-direction: column; gap: 10px; max-width: 300px; margin: 0 auto; text-align: left; }

.step { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--sub); transition: color 0.3s; }
.step.done { color: var(--green); }
.step.active { color: var(--text); font-weight: 500; }

.step-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--border);
  flex-shrink: 0;
  transition: background 0.3s;
}

.step.done .step-dot { background: var(--green); }
.step.active .step-dot { background: var(--red); animation: blink 1s infinite; }

@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* ── RESULTS ── */
#results { display: none; }
#results.show { display: block; }

/* Channel card */
.channel-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 22px;
  margin-bottom: 20px;
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
}

.ch-thumb {
  width: 72px; height: 72px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  border: 2px solid var(--border);
}

.ch-thumb-placeholder {
  width: 72px; height: 72px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--red), var(--orange));
  display: flex; align-items: center; justify-content: center;
  font-size: 28px;
  flex-shrink: 0;
}

.ch-info { flex: 1; }

.ch-name {
  font-size: 20px;
  font-weight: 800;
  margin-bottom: 2px;
  letter-spacing: -0.3px;
}

.ch-handle { font-size: 13px; color: var(--sub); font-family: var(--mono); margin-bottom: 8px; }

.ch-desc {
  font-size: 13px;
  color: var(--sub);
  line-height: 1.6;
  margin-bottom: 12px;
}

.ch-stats {
  display: flex; gap: 12px; flex-wrap: wrap;
}

.stat {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 8px 16px;
  text-align: center;
}

.stat-val { font-size: 16px; font-weight: 800; color: var(--red); }
.stat-lbl { font-size: 10px; color: var(--sub); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 1px; }

/* Analysis summary */
.analysis-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 22px;
  margin-bottom: 20px;
}

.analysis-card h3 {
  font-size: 13px;
  font-weight: 700;
  color: var(--sub);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 14px;
}

.analysis-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
  gap: 10px;
}

.analysis-item {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px;
}

.analysis-item .label {
  font-size: 10px;
  font-weight: 700;
  color: var(--sub);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 6px;
}

.analysis-item .value {
  font-size: 13px;
  font-weight: 600;
  line-height: 1.5;
  color: var(--text);
}

/* Section headers */
.section-hd {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 28px 0 14px;
}

.section-hd h2 { font-size: 17px; font-weight: 800; }

.badge {
  font-size: 10px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.badge-red { background: var(--red-dim); color: var(--red); }
.badge-green { background: rgba(0,217,126,0.1); color: var(--green); }
.badge-orange { background: rgba(255,140,0,0.1); color: var(--orange); }

/* Topic cards */
.topics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
  gap: 14px;
}

.topic-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 20px;
  transition: border-color 0.2s, transform 0.2s;
  position: relative;
  overflow: hidden;
}

.topic-card::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  opacity: 0;
  transition: opacity 0.2s;
}

.topic-card.trending::after { background: linear-gradient(90deg, var(--red), var(--orange)); }
.topic-card.info::after { background: linear-gradient(90deg, var(--blue), var(--purple)); }

.topic-card:hover { transform: translateY(-3px); }
.topic-card.trending:hover { border-color: rgba(255,59,59,0.4); }
.topic-card.info:hover { border-color: rgba(79,159,255,0.4); }
.topic-card:hover::after { opacity: 1; }

.topic-type {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 10px;
  display: flex; align-items: center; gap: 6px;
}

.type-trending { color: var(--red); }
.type-info { color: var(--blue); }

.topic-num {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--border);
  margin-left: auto;
}

.topic-title {
  font-size: 14px;
  font-weight: 700;
  line-height: 1.45;
  margin-bottom: 10px;
}

.topic-why {
  font-size: 12px;
  color: var(--sub);
  line-height: 1.65;
  margin-bottom: 14px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--border);
}

.hook-box {
  background: var(--card);
  border-radius: 10px;
  padding: 12px;
  margin-bottom: 12px;
}

.hook-label {
  font-size: 10px;
  font-weight: 700;
  color: var(--orange);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 6px;
}

.hook-text {
  font-size: 13px;
  font-style: italic;
  line-height: 1.6;
  color: var(--text);
}

.score-row {
  display: flex; align-items: center; gap: 8px; margin-bottom: 6px;
}

.score-lbl { font-size: 10px; color: var(--sub); width: 70px; }

.score-bar {
  flex: 1; height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
}

.score-fill {
  height: 100%; border-radius: 2px;
  transition: width 1.2s ease;
}

.fill-red { background: linear-gradient(90deg, var(--red), var(--orange)); }
.fill-blue { background: linear-gradient(90deg, var(--blue), var(--purple)); }

.score-num { font-size: 11px; font-weight: 700; width: 28px; text-align: right; font-family: var(--mono); }
.score-num.red { color: var(--red); }
.score-num.blue { color: var(--blue); }

/* Tags */
.topic-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
.tag {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 3px 8px;
  font-size: 10px;
  color: var(--sub);
  font-family: var(--mono);
}

/* Footer note */
.footer-note {
  margin-top: 32px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px 20px;
  font-size: 12px;
  color: var(--sub);
  line-height: 1.7;
  display: flex; gap: 10px;
}

/* Responsive */
@media(max-width:580px) {
  .topics-grid { grid-template-columns: 1fr; }
  .ch-stats { gap: 8px; }
  .stat { padding: 7px 12px; }
}
</style>
